.venv/
__pycache__/
*.pyc

# Raw data is fetched, not redistributed here (see src/00_fetch.py): the
# Fama-French files derive from restricted CRSP data. The exception is the NBER
# recession series, which is public domain — we keep it in the repo (with credit)
# so the pipeline still runs when FRED is unreachable.
data/raw/*
!data/raw/USREC.csv

